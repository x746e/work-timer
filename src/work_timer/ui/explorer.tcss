Timer {
    align-vertical: middle;

    .break {
        background: lavenderblush;
        color: black;
    }

    #title {
        text-align: center;
        text-style: bold;
        width: 1fr;
        padding-bottom: 1;
    }

    TimeDisplay {
        text-align: center;
    }

    ProgressBar {
        width: 1fr;
        align: center middle;
    }
}


TaskEditorWidget {
    Grid {
	padding: 1 2;
	height: auto;
	grid-size: 2;
	grid-gutter: 1;
	grid-columns: auto 1fr;
    }

    Label {
        width: 100%;
        padding: 1;
        text-align: right;
    }

    #text-container {
        layout: grid;
        grid-size: 2;
        grid-gutter: 1;
	grid-columns: auto 1fr;

        TextArea {
            height: 10;
            width: 100%;
            margin-right: 2;
        }
    }

    #buttons {
        align-vertical: bottom;
    }
}


PPlayground {
    #static-3 {
        border: panel cornflowerblue 60%;
    }
    #con-4 {
        height: 4;
        align: center middle;
    }
    #con-5-6-7 {
        align: center bottom;
        /* content-align: right bottom; */
        layout: horizontal;
    }
    #static-5, #static-6 {
        border: hkey red;
        width: auto;
        /*padding: 0 5;*/
        height: 3;
        /*margin: 3;*/
    }
    #static-5 {
        /* box-sizing: border-box; */
    }
    #static-6 {
        /* box-sizing: content-box; */
    }
    #static-7 {
        width: auto;
    }
}
